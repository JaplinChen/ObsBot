# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Obsidian Vault path (absolute path)
# 本機執行：填你的 vault 絕對路徑
# Docker：不用改（容器內固定為 /vault，由 HOST_VAULT_PATH 掛載）
VAULT_PATH=/Users/yourname/ObsidianVault

# Docker 專用：主機上的 Obsidian Vault 路徑（docker compose 會掛載到容器內 /vault）
# 本機執行時此變數不會使用
HOST_VAULT_PATH=/Users/yourname/ObsidianVault

# Allowed Telegram user IDs (comma-separated, leave empty to allow all)
ALLOWED_USER_IDS=

# Enable Simplified → Traditional Chinese translation (true/false)
ENABLE_TRANSLATION=true

# Max external URLs to fetch metadata per post (default: 5)
MAX_LINKED_URLS=5

# Save downloaded videos to vault attachments (default: false)
# Videos are still temporarily downloaded for transcription but not kept in vault
SAVE_VIDEOS=false

# oMLX local inference (optional, takes priority over remote providers)
# Requires oMLX running on your Mac: https://github.com/nicfab/omlx
# Models: flash→4B, standard→9B, deep→27B (auto-selected by task tier)
OMLX_API_KEY=
# OMLX_BASE_URL=http://127.0.0.1:8000  # 預設值，Docker 用戶可改為 host.docker.internal

# Cloudflare Quick Tunnel — Research 介面的 Basic Auth
# 設定後 /research 與 /api/research/* 需要帳密才能存取
# 未設定時本機 127.0.0.1 直接放行，Tunnel 對外時務必設定！
RESEARCH_USER=obsbot
RESEARCH_PASS=your_password_here

# Telegram backup channel ID (optional, for vault note backup)
# Get your channel ID from @userinfobot after adding the bot as admin
# Note: channel IDs start with -100, e.g. -1001234567890
BACKUP_CHANNEL_ID=
