{
  "name": "getthreads",
  "version": "1.0.0",
  "description": "Telegram Bot to extract X.com/Threads content and save to Obsidian",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "camoufox-js": "^0.9.1",
    "dotenv": "^17.3.1",
    "opencc-js": "^1.0.5",
    "playwright-core": "^1.58.2",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
