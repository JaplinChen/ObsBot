{
  "name": "getthreads",
  "version": "1.0.0",
  "description": "Telegram Bot to extract X.com/Threads content and save to Obsidian",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "restart": "tsx scripts/restart-bot.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts",
    "postinstall": "bash scripts/postinstall.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "camoufox-js": "^0.9.1",
    "dotenv": "^17.3.1",
    "linkedom": "^0.18.12",
    "opencc-js": "^1.0.5",
    "pdf-parse": "^2.4.5",
    "playwright-core": "^1.58.2",
    "telegraf": "^4.16.3",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@gradio/client": "^2.1.0",
    "@huggingface/inference": "^4.13.15",
    "@types/node": "^25.4.0",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
