{
  "name": "knowpipe",
  "version": "1.0.1",
  "description": "Telegram Bot that auto-extracts content from 20+ platforms and saves to Obsidian Vault",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:loop": "node scripts/loop.mjs --dev",
    "start:loop": "node scripts/loop.mjs",
    "restart": "tsx scripts/restart-bot.ts",
    "build": "tsc && node scripts/copy-assets.mjs",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts",
    "setup": "node scripts/setup.mjs",
    "postinstall": "node scripts/postinstall.mjs",
    "app:install": "cd electron && npm install",
    "app:dev": "npm run build && cd electron && npm run dev",
    "app:pack:mac-arm64": "npm run build && cd electron && npm run pack:mac-arm64",
    "app:pack:mac-x64": "npm run build && cd electron && npm run pack:mac-x64",
    "app:pack:win": "npm run build && cd electron && npm run pack:win",
    "app:pack:all": "npm run build && cd electron && npm run pack:all"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "camoufox-js": "^0.9.1",
    "dotenv": "^17.3.1",
    "linkedom": "^0.18.12",
    "opencc-js": "^1.0.5",
    "pdf-parse": "^2.4.5",
    "playwright-core": "^1.58.2",
    "pptxgenjs": "^4.0.1",
    "telegraf": "^4.16.3",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@gradio/client": "^2.1.0",
    "@huggingface/inference": "^4.13.15",
    "@types/node": "^25.4.0",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
